#include <iostream> // Ввод‑вывод
#include <cmath> // математические функции (abs)
using namespace std; // Стандартное пространство имён

int main() // Начало 
{
    double x, y; // Координаты точки

    cin >> x >> y; // Ввод x и y

    if (y > abs(x)) 
{
        cout << "Да"; // Точка выше границы (y > x)
    }
    else if (y == abs(x)) 
{
        cout << "На границе";  // Точка на границе (y = x)
    }
    else {
        cout << "Нет";  // Точка ниже границы (y < x)
    }
return 0; // Успешное завершение
}
